# Required for /api/chat
OPENAI_API_KEY=

# Optional: canonical public URL (no trailing slash). Improves chat deep links locally and if VERCEL_URL is wrong.
# NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app

# Optional: GitHub "blob/main" root so tool payloads include viewOnGithub links, e.g.
# NEXT_PUBLIC_GITHUB_FILE_BASE=https://github.com/youruser/yourrepo/blob/main
